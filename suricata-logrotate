/var/log/suricata/*.log
/var/log/suricata/*.json
{
    daily
    rotate 7
    compress
    delaycompress
    missingok
    notifempty
    sharedscripts
    postrotate
        # Signal Suricata to reopen log files after rotation
        kill -HUP $(cat /var/run/suricata.pid 2>/dev/null) 2>/dev/null || true
        # Give Suricata a moment to reopen before tailer reconnects
        sleep 1
    endscript
}
